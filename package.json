{
	"name": "personal-finance",
	"version": "0.1.0",
	"private": true,
	"main": "dist-electron/main.js",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"electron:compile": "tsc --project electron/tsconfig.json",
		"electron:dev": "concurrently --kill-others \"next dev\" \"wait-on http://127.0.0.1:3000 && cross-env NODE_ENV=development electron .\"",
		"electron:build": "npx tsx scripts/electron-build.ts",
		"electron:build:mac": "npx tsx scripts/electron-build.ts --mac",
		"electron:build:win": "npx tsx scripts/electron-build.ts --win",
		"electron:build:linux": "npx tsx scripts/electron-build.ts --linux"
	},
	"dependencies": {
		"@base-ui/react": "^1.1.0",
		"@hookform/resolvers": "^5.2.2",
		"better-sqlite3": "^12.6.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"imapflow": "^1.2.8",
		"lucide-react": "^0.563.0",
		"mailparser": "^3.9.3",
		"next": "16.1.6",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-day-picker": "^9.13.1",
		"react-dom": "19.2.3",
		"react-hook-form": "^7.71.1",
		"shadcn": "^3.8.2",
		"tailwind-merge": "^3.4.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@tailwindcss/postcss": "^4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/mailparser": "^3.4.6",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^40.6.1",
		"electron-builder": "^26.8.1",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"tailwindcss": "^4",
		"tsx": "^4.21.0",
		"typescript": "^5",
		"wait-on": "^9.0.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"electron"
		],
		"overrides": {
			"zod": "4.3.6"
		},
		"ignoredBuiltDependencies": [
			"electron-winstaller"
		]
	}
}
